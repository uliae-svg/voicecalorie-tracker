# ────────────────────────────────────────────────────────
# .env.example — шаблон (коммитится в Git, ключей нет)
#
# Для начала работы:
#   cp .env.example .env
#   # заполнить .env реальными ключами
# ────────────────────────────────────────────────────────

VITE_EDAMAM_APP_ID=your_app_id_here
VITE_EDAMAM_APP_KEY=your_app_key_here

# Groq API — бесплатный AI (Llama 3.3 70B)
# Получить ключ: https://console.groq.com/
VITE_GROQ_API_KEY=your_groq_api_key_here
